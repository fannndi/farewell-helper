{
  "$schema": "https://opencode.ai/config.json",
  "model": "9router/FREE_Model",
  "default_agent": "build",
  "provider": {
    "9router": {
      "name": "9Router Gateway",
      "env": [
        "NINEROUTER_API_KEY"
      ],
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_API_KEY}",
        "setCacheKey": true,
        "timeout": 300000,
        "headerTimeout": 300000,
        "chunkTimeout": 300000
      },
      "models": {
        "FREE_Model": {
          "name": "FREE_Model",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Execution_Paid": {
          "name": "Execution_Paid",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Pro_Plan": {
          "name": "Pro_Plan",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Codex": {
          "name": "Codex",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        }
      }
    }
  },
  "instructions": [
    "PERSONA.md",
    "PROTOCOL.md"
  ],
  "agent": {
    "build": {
      "description": "Farewell Helper - full access, eksekusi",
      "mode": "primary",
      "model": "9router/Execution_Paid",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "deny"
      }
    },
    "plan": {
      "description": "Farewell Helper - read-only, analisis & rencana",
      "mode": "primary",
      "model": "9router/Pro_Plan",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "find *": "allow",
          "rg *": "allow",
          "tree *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "dir *": "allow",
          "echo *": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "question": "allow",
        "task": "deny"
      }
    },
    "general": {
      "disable": true,
      "mode": "subagent"
    },
    "explore": {
      "disable": true,
      "mode": "subagent"
    }
  },
  "mcp": {
    "farewell-helper": {
      "type": "local",
      "command": [
        "py",
        "-m",
        "farewell_helper.mcp",
        "--stdio"
      ],
      "enabled": true,
      "environment": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  },
  "skills": {
    "paths": [
      "skills"
    ]
  },
  "experimental": {
    "policies": [
      {
        "action": "provider.use",
        "effect": "deny",
        "resource": "*"
      },
      {
        "action": "provider.use",
        "effect": "allow",
        "resource": "9router"
      }
    ]
  },
  "compaction": {
    "auto": true,
    "buffer": 10000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".pytest_cache/**",
      "__pycache__/**",
      ".venv/**",
      "venv/**",
      "node_modules/**",
      "*.pyc"
    ]
  },
  "formatter": {
    "python": {
      "command": [
        "ruff",
        "format",
        "--stdin-filename",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    }
  },
  "lsp": true,
  "command": {
    "/daily": {
      "description": "Health check + sync combo + resolve config",
      "template": "py -m farewell_helper daily $ARGUMENTS"
    },
    "/sync": {
      "description": "Sync 9Router combos + resolve opencode config",
      "template": "py -m farewell_helper sync $ARGUMENTS"
    },
    "/verify": {
      "description": "Verify persona + config injection system",
      "template": "py -m farewell_helper verify $ARGUMENTS"
    },
    "/start": {
      "description": "Session start: validate persona, show active project",
      "template": "py -m farewell_helper start $ARGUMENTS"
    },
    "/health": {
      "description": "Full project health report",
      "template": "py -m farewell_helper health $ARGUMENTS"
    },
    "/pre-commit": {
      "description": "Quality gate: run tests, check TODOs",
      "template": "py -m farewell_helper pre-commit $ARGUMENTS"
    }
  }
}
