{
  "$schema": "https://opencode.ai/config.json",
  "model": "9router/FREE_Model",
  "default_agent": "Farewell",
  "subagent_depth": 3,
  "provider": {
    "9router": {
      "name": "9Router Gateway",
      "env": [
        "NINEROUTER_API_KEY"
      ],
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "{env:NINEROUTER_API_KEY}",
        "setCacheKey": true,
        "timeout": 300000,
        "headerTimeout": 300000,
        "chunkTimeout": 300000
      },
      "models": {
        "FREE_Model": {
          "name": "FREE_Model",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Execution_Paid": {
          "name": "Execution_Paid",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Pro_Plan": {
          "name": "Pro_Plan",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Codex": {
          "name": "Codex",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Pro": {
          "name": "Pro",
          "reasoning": false,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Flash": {
          "name": "Flash",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "FREE_OC": {
          "name": "FREE_OC",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "FREE_OR": {
          "name": "FREE_OR",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Experiment": {
          "name": "Experiment",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "Free": {
          "name": "Free",
          "reasoning": false,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        }
      }
    }
  },
  "instructions": [
    "PERSONA.md"
  ],
  "references": {
    "farewell-helper": {
      "path": ".",
      "description": "Farewell Helper \u2014 OpenCode agent + 9Router model gateway + skills + persona system"
    },
    "9router": {
      "path": "source/9router",
      "hidden": true
    },
    "opencode": {
      "path": "source/opencode",
      "hidden": true
    }
  },
  "agent": {
    "build": {
      "description": "Farewell Helper - full access, eksekusi",
      "mode": "primary",
      "model": "9router/Execution_Paid",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "deny"
      }
    },
    "plan": {
      "description": "Farewell Helper - read-only, analisis & rencana",
      "mode": "primary",
      "model": "9router/Pro_Plan",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "find *": "allow",
          "rg *": "allow",
          "tree *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "dir *": "allow",
          "echo *": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "question": "allow",
        "task": "deny"
      }
    },
    "general": {
      "disable": true,
      "mode": "subagent"
    },
    "explore": {
      "disable": true,
      "mode": "subagent"
    },
    "executor": {
      "mode": "subagent",
      "model": "9router/Flash",
      "description": "Eksekutor kode \u2014 dipanggil Farewell untuk nulis dan eksekusi",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow"
      }
    },
    "validator": {
      "mode": "subagent",
      "model": "9router/Free",
      "description": "Validator \u2014 verifikasi persona, skill usage, dan codebase-memory utilization",
      "prompt": "You are a validation agent. Two modes. Respond with JSON only. No extra text.\n\n## Mode 1 \u2014 Verification (boot/periodic/pre-audit)\nCheck: (a) skills loaded via skill tool match domain? (b) codebase-memory tools used instead of grep/read? (c) SESSION_CTX complete?\nOutput: {\"mode\":\"verification\",\"verdict\":\"pass|fail|warn\",\"skill_used\":true|false,\"codebase_memory_used\":true|false,\"issues\":[]}\n\n## Mode 2 \u2014 Pre-executor Brief (sebelum executor kerjakan TODO)\nThe planner prompt will include the TODO task description. Your job: siapkan BEKAL untuk executor.\n1. Cari codebase-memory: search_graph + trace_path untuk function/file terkait task\n2. Identifikasi skill yang relevan dari domain-skill mapping\n3. Sertakan persona rules kunci dari PERSONA.md yang relevan\nOutput: {\"mode\":\"pre-executor\",\"bekal\":{\"codebase_memory_context\":\"ringkasan hasil search_graph/trace_path\",\"relevant_skills\":[\"skill1\",\"skill2\"],\"persona_rules\":\"ringkasan rules yang berlaku untuk task ini\"}}\n\n## Domain-Skill Mapping\n- Code analysis/audit \u2192 codebase-memory (search_graph,trace_path,get_architecture) + farewell-audit\n- Bug diagnosis \u2192 farewell-diagnosing-bugs\n- API \u2192 farewell-api-design\n- TDD/build \u2192 farewell-tdd\n- DevOps/DB \u2192 farewell-devops\n- Git \u2192 farewell-git\n- Error handling \u2192 farewell-error-handling\n- Production audit \u2192 farewell-production-audit\n- PRD/spec \u2192 farewell-prd\n- Workspace setup \u2192 farewell-workspace-audit\n- Python \u2192 farewell-python\n- Flutter \u2192 farewell-flutter\n- Rust \u2192 farewell-rust\n- C \u2192 farewell-c\n- Frontend \u2192 farewell-frontend\n- Ambiguous tasks \u2192 farewell-grilling\n- New session/identity \u2192 farewell-persona\n\n## Codebase-Memory Tools\nsearch_graph, trace_path, get_architecture, query_graph, search_code, get_code_snippet.\n\nDefault: Mode 1. Gunakan Mode 2 hanya jika prompt planner minta bekal untuk executor.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow"
      }
    },
    "Farewell": {
      "mode": "primary",
      "model": "9router/Pro",
      "description": "Farewell \u2014 Pro reasoning, Flash execution via executor subagent",
      "temperature": 0.7,
      "topP": 0.95,
      "prompt": "Anda adalah Farewell. 3 role: planner (anda), coder (executor), checker (validator). WAJIB: (1) delegasi SEMUA penulisan/editan kode ke task(subagent_type:\"executor\"), (2) delegasi SEMUA baca/analisis kode asing ke codebase-memory tools (search_graph, trace_path), (3) panggil task(subagent_type:\"validator\") di boot setelah skill load, SEBELUM code analysis asing, dan setiap ~5 turn. JANGAN pernah edit/tulis file langsung \u2014 edit:deny. JANGAN guna grep/read untuk code analysis \u2014 guna codebase-memory. JANGAN silent. Laporkan hasil tiap step ke Boss. DETEKSI SESSION STALE: jika ada history percakapan dari hari SEBELUMNYA, WAJIB bilang \"Session dari hari sebelumnya. Jalankan /start dan /daily dulu.\" JANGAN lanjut bekerja sebelum Boss\u6267\u884c /start.",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow"
      }
    }
  },
  "mcp": {
    "farewell-helper": {
      "type": "local",
      "command": [
        "py",
        "-m",
        "farewell_helper.mcp",
        "--stdio"
      ],
      "enabled": true,
      "environment": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "codebase-memory": {
      "type": "local",
      "command": [
        "codebase-memory-mcp"
      ],
      "enabled": true
    }
  },
  "skills": {
    "paths": [
      "skills"
    ]
  },
  "experimental": {
    "primary_tools": [
      "todowrite",
      "plan_enter",
      "plan_exit",
      "question"
    ],
    "policies": [
      {
        "action": "provider.use",
        "effect": "deny",
        "resource": "*"
      },
      {
        "action": "provider.use",
        "effect": "allow",
        "resource": "9router"
      }
    ]
  },
  "compaction": {
    "auto": true,
    "buffer": 50000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".pytest_cache/**",
      "__pycache__/**",
      ".venv/**",
      "venv/**",
      "node_modules/**",
      "*.pyc"
    ]
  },
  "formatter": {
    "python": {
      "command": [
        "ruff",
        "format",
        "--stdin-filename",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    }
  },
  "lsp": true,
  "command": {
    "/daily": {
      "description": "Health check + sync combo + resolve config",
      "template": "py -m farewell_helper daily $ARGUMENTS"
    },
    "/sync": {
      "description": "Sync 9Router combos + resolve opencode config",
      "template": "py -m farewell_helper sync $ARGUMENTS"
    },
    "/verify": {
      "description": "Verify persona + config injection system",
      "template": "py -m farewell_helper verify $ARGUMENTS"
    },
    "/start": {
      "description": "Session start: validate persona, show active project",
      "template": "py -m farewell_helper start $ARGUMENTS"
    },
    "/sub-project": {
      "description": "Sub-project assistant: dashboard, switch, or register projects",
      "template": "py -m farewell_helper sub-project $ARGUMENTS"
    },
    "/health": {
      "description": "Full project health report",
      "template": "py -m farewell_helper health $ARGUMENTS"
    },
    "/pre-commit": {
      "description": "Quality gate: run tests, check TODOs",
      "template": "py -m farewell_helper pre-commit $ARGUMENTS"
    }
  }
}
